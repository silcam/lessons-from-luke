{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es2022",
    "moduleResolution": "node",
    "sourceMap": true,
    "strictNullChecks": true,
    "strict": true,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0"
  },
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    // Jest-only infra: transformed by ts-jest from source (see jest.config.js),
    // never consumed from dist/. Keeping these out of the build matters because
    // jestSetupAfterEnv.ts imports ../testSupport/jestSilenceConsole (outside
    // src/server) — pulling it into the server program would drag the inferred
    // rootDir up to src/ and nest every output (dist/server/server/server.js).
    "**/jestGlobalSetup.ts",
    "**/jestSetupAfterEnv.ts",
    "**/jestSilenceConsole.ts",
    // Cypress E2E specs have their own runtime (browser, mocha/chai globals) and
    // are never part of the app build. This config has no "include", so without
    // this exclusion any *.ts file under cypress/ is swept into the default
    // include — and Cypress's bundled global Chai typings (Assertion/expect)
    // then clobber @types/jest's `expect` for every ts-jest consumer that falls
    // back to this root config (no project pins an explicit tsconfig path —
    // see jest.config.js), breaking `expect(...).toHaveBeenCalledWith` etc.
    // project-wide.
    "cypress"
  ]
}
