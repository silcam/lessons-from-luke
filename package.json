{
  "name": "lessons-from-luke",
  "description": "Sunday School curriculum for every language.",
  "author": "Rick Conrad",
  "productName": "Lessons from Luke",
  "version": "2.2.5",
  "license": "MIT",
  "main": "dist/desktop/desktop/main.js",
  "build": {
    "appId": "org.sil.cmb.lessons-from-luke",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "**/*",
      "!art",
      "!config",
      "!cypress",
      "!docs",
      "!lib",
      "!log",
      "!migrations",
      "!src",
      "!strings",
      "!test",
      "!webpack"
    ]
  },
  "scripts": {
    "dev-web": "NODE_ENV=development concurrently -k -p \"[{name}]\" -n \"WebpackDevServe,Typescript,Server\" -c \"yellow.bold,blue.bold,green.bold\" \"yarn wpDevServerWeb\" \"tsc -b -w ./src/server\" \"yarn serve-dev\"",
    "dev-desktop": "NODE_ENV=development concurrently -k -p \"[{name}]\" -n \"Webpack,Typescript,Electron\" -c \"yellow.bold,blue.bold,green.bold\" \"yarn wpDevServerDesktop\" \"tsc -b -w ./src/desktop ./src/server\" \"yarn run-test-desktop\"",
    "wpDevServerWeb": "webpack-dev-server --config webpack/web.development.config.js --host 0.0.0.0",
    "wpDevServerDesktop": "webpack-dev-server --config webpack/desktop.development.config.js",
    "serve": "NODE_ENV=test nodemon -w dist/server/ --exec \"node dist/server/server.js\"",
    "serve-dev": "NODE_ENV=development nodemon -w dist/server/ --exec \"node dist/server/server.js\"",
    "run-test-desktop": "nodemon -w dist/desktop/ --exec yarn electron dist/desktop/main-test.js",
    "migrate": "node scripts/migrate.js",
    "migrate:dev": "DEV_DB=true node scripts/migrate.js",
    "migrate:test": "TEST_DB=true node scripts/migrate.js",
    "reset:dev": "node scripts/reset-dev.js",
    "seed-dev-docs": "node scripts/seed-dev-docs.js",
    "test": "NODE_ENV=test jest --watchAll --runInBand",
    "test:once": "NODE_ENV=test jest --runInBand --watchAll=false",
    "test:random": "NODE_ENV=test jest --runInBand --watchAll=false --testSequencer=./RandomSequencer.js",
    "test:reverse": "NODE_ENV=test jest --runInBand --watchAll=false --testSequencer=./ReverseSequencer.js",
    "test:verify": "bash scripts/verify-tests.sh",
    "test-coverage": "NODE_ENV=test jest --runInBand --coverage",
    "test:frontend": "NODE_ENV=test npx jest --config jest.frontend.config.js --runInBand --watchAll=false",
    "test:integration": "NODE_ENV=test npx jest --config jest.integration.config.js --runInBand --watchAll=false",
    "test-desktop-e2e": "jest -c jest.playwright-electron.config.js",
    "test-desktop-e2e-deps": "NODE_ENV=test concurrently -k -p \"[{name}]\" -n \"Webpack,Server\" -c \"yellow.bold,blue.bold\" \"yarn wpDevServerDesktop\" \"yarn serve\"",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:random": "cypress run --spec $(node scripts/shuffle-cypress-specs.js)",
    "test-e2e": "concurrently --kill-others -p \"[{name}]\" -n \"Cypress,WebpackDevServe,Server\" -c \"blue.bold,yellow.bold,green.bold\" \"wait-on http://localhost:8080 && cypress run\" \"yarn wpDevServerWeb\" \"yarn serve\"",
    "deploy": "bundle exec cap production deploy",
    "build-server": "tsc -b ./src/server/tsconfig.prod.json && webpack --config webpack/web.production.config.js",
    "build-desktop": "rm -fR dist && tsc -b ./src/desktop/tsconfig.prod.json && webpack --config webpack/desktop.production.config.js && node build-desktop.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b ./src/core && tsc --noEmit -p ./src/core/tsconfig.typecheck.json && tsc --noEmit -p ./src/server/tsconfig.typecheck.json && tsc --noEmit -p ./src/desktop/tsconfig.typecheck.json && tsc --noEmit -p ./src/frontend/tsconfig.typecheck.json",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "bash -c 'NODE_ENV=test npx jest --findRelatedTests --bail --passWithNoTests --runInBand \"$@\"' --"
    ],
    "**/*.{js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@reduxjs/toolkit": "^2.6.1",
    "@types/diff": "^5.0.0",
    "@types/express": "^4.17.2",
    "@types/express-fileupload": "^1.1.0",
    "@types/file-saver": "^2.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-redux": "^7.1.5",
    "@types/string-similarity": "^3.0.0",
    "@types/styled-components": "^5.1.26",
    "@types/supertest": "^2.0.8",
    "axios": "^1.7.0",
    "better-auth": "^1.6.14",
    "body-parser": "^1.20.3",
    "diff": "^7.0.0",
    "electron-context-menu": "^3.0.0",
    "electron-default-menu": "^1.0.2",
    "electron-window-state": "^5.0.3",
    "express": "^4.21.2",
    "express-fileupload": "^1.1.9",
    "file-saver": "^2.0.2",
    "helmet": "^8.2.0",
    "html-webpack-plugin": "^5.6.3",
    "immer": "^9.0.6",
    "immutability-helper": "^3.0.1",
    "jest": "^29.7.0",
    "libxmljs2": "^0.37.0",
    "migrate": "^1.6.2",
    "pg": "^8.21.0",
    "postgres": "^1.0.2",
    "prexit": "^0.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^10.2.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.0",
    "string-similarity": "^4.0.1",
    "styled-components": "^5.0.0",
    "supertest": "^7.0.0",
    "ts-loader": "^8.4.0",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/react": "^16.3.0",
    "@types/eslint-plugin-jsx-a11y": "^6",
    "concurrently": "^7.0.0",
    "cypress": "^13.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^17.0.7",
    "nodemon": "^2.0.0",
    "playwright": "^1.50.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.2.5",
    "typescript-eslint": "^8.60.1",
    "wait-on": "^9.0.5",
    "webpack": "^5.99.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-middleware": "^7.4.2",
    "webpack-dev-server": "^5.2.0"
  },
  "desktopBuildDependencies": {
    "axios": "^1.7.0",
    "electron-context-menu": "^3.0.0",
    "electron-default-menu": "^1.0.2",
    "electron-window-state": "^5.0.3",
    "immer": "^9.0.6",
    "immutability-helper": "^3.0.1"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
