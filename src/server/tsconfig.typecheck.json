// Type-check-only config: like ./tsconfig.json but with NO emit and tests
// (and jest infra) re-included, so `yarn typecheck` covers *.test.ts too.
// References core for its built declarations (run `tsc -b ./src/core` first).
// The build/emit path (dev `tsc -b -w ./src/server`, tsconfig.prod.json) keeps
// using ./tsconfig.json, which still excludes tests so dist/ stays clean.
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "exclude": ["node_modules"]
}
